{
  "type": "object",
  "required": ["service_name"],
  "properties": {
    "service_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Kebab-case service name."
    },
    "output_dir": {
      "type": "string",
      "minLength": 1,
      "description": "Optional base directory for generated files. Defaults to /app/generated/<project_id>."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "default": 3000
    },
    "repo_url": {
      "type": "string",
      "description": "Optional output repo URL; defaults to local file:// path."
    }
  },
  "additionalProperties": true
}
