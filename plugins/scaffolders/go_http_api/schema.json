{
  "type": "object",
  "required": ["service_name", "owner", "output_dir"],
  "properties": {
    "service_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Kebab-case service name."
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "module_path": {
      "type": "string",
      "default": "github.com/acme"
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "default": 8080
    },
    "repo_url": {
      "type": "string",
      "description": "Optional output repo URL; defaults to local file:// path."
    }
  },
  "additionalProperties": true
}
