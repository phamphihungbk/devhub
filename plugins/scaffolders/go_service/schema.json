{
  "type": "object",
  "required": ["service_name", "repo_url"],
  "properties": {
    "service_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Kebab-case service name."
    },
    "output_dir": {
      "type": "string",
      "minLength": 1,
      "description": "Optional base directory for generated files. Defaults to /app/generated/<project_id>."
    },
    "module_path": {
      "type": "string",
      "default": "github.com/acme"
    },
    "repo_url": {
      "type": "string",
      "minLength": 1,
      "description": "Required output repo URL returned by the scaffolder."
    }
  },
  "additionalProperties": true
}
