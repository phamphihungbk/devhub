# Core service configuration
SERVICE_ENV=development
DATABASE_URL=postgres://devhub:devhubpass@db:5432/devhub?sslmode=disable

# Database configuration
POSTGRES_USER=devhub
POSTGRES_PASSWORD=devhubpass
POSTGRES_DB=devhub

# HTTPS gateway configuration
DEVHUB_DOMAIN=devhub.local
DEVHUB_API_DOMAIN=api.devhub.local
DEVHUB_SSL_CERT_FILE=devhub.local.crt
DEVHUB_SSL_KEY_FILE=devhub.local.key
