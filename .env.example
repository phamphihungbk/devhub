# Backend runtime configuration
SERVICE_ENV=development
DATABASE_URL=postgres://devhub:devhubpass@db:5432/devhub?sslmode=disable
APP_TIMEZONE=Asia/Hanoi

# ArgoCD configuration
ARGOCD_SERVER=host.docker.internal:8081
ARGOCD_INSECURE=true
ARGOCD_AUTH_TOKEN=
ARGOCD_APP_PROJECT=default
ARGOCD_APP_NAMESPACE=devhub
ARGOCD_TARGET_REVISION=main
ARGOCD_REPO_URL=http://host.minikube.internal:3000
ARGOCD_REPOSITORY_REGISTRY_HOST=host.minikube.internal:5001

# CI configuration used by scaffold/deploy plugins
CI_IMAGE_REGISTRY_HOST=host.docker.internal:5001
CI_SERVER_URL=http://host.docker.internal:3000

# Database configuration
POSTGRES_USER=devhub
POSTGRES_PASSWORD=devhubpass
POSTGRES_DB=devhub
POSTGRES_HOST_PORT=5433

# HTTPS gateway configuration
DEVHUB_DOMAIN=devhub.local
DEVHUB_API_DOMAIN=api.devhub.local
DEVHUB_SSL_CERT_FILE=devhub.local.crt
DEVHUB_SSL_KEY_FILE=devhub.local.key

# Optional Gitea publishing for scaffold workers
SCM_API_URL=http://gitea:3000/api/v1
SCM_EXTERNAL_URL=https://gitea.devhub.local
SCM_INTERNAL_URL=http://host.docker.internal:3000
SCM_TOKEN=
SCM_TIMEOUT=10s

GITOPS_REPO_OWNER=phamphihungbk
GITOPS_REPO_URL=http://host.minikube.internal:3000/phamphihungbk/gitops-repo.git
GITOPS_REPO_BRANCH=main
GITOPS_REPO_NAME=gitops-repo
GITOPS_ENV_GLOB=envs/*/*.yaml
GITOPS_BRANCH=main
GITOPS_BASE_PATH=envs
GITOPS_COMMIT_USER_NAME=devhub-bot
GITOPS_COMMIT_USER_EMAIL=devhub-bot@local
GITOPS_TIMEOUT=10s

# Optional Gitea Actions runner
GITEA_RUNNER_INSTANCE_URL=http://gitea:3000
GITEA_RUNNER_REGISTRATION_TOKEN=
GITEA_RUNNER_NAME=devhub-runner
GITEA_RUNNER_LABELS=linux:docker://docker:27-cli
